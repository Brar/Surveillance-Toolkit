{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "NeoIPC build documentation",
            "type": "shell",
            "command": "${workspaceFolder}/doc/build.ps1",
            "args": [
                "-InformationAction",
                "Continue"
            ],
            "problemMatcher": [
                // {
                //     "owner": "build.ps1",
                //     "pattern": {
                //         "regexp": "^(WARNING|ERROR|INFO):\\s+(.+)$",
                //         "severity": 1,
                //         "message": 2
                //     }
                // },
                {
                    "owner": "build.ps1",
                    "fileLocation": [
                        "absolute"
                    ],
                    "pattern": [
                        {
                            "regexp": "^Write-(Warning|Error):\\s+([A-Z]:[^:]+):(\\d+):(\\d+)$",
                            "severity": 1,
                            "file": 2,
                            "line": 3,
                            "column": 4
                        },
                        {
                            "regexp": "^Line\\s\\|\\s*$"
                        },
                        {
                            "regexp": "^\\s*\\d*\\s*\\|.*"
                        },
                        {
                            "regexp": "^\\s*\\|\\s*~~+\\s*$"
                        },
                        {
                            "regexp": "^\\s*\\|\\s*([^~].*)\\s*$",
                            "message": 1
                        }
                    ]
                },
                {
                    "owner": "build.ps1",
                    "fileLocation": [
                        "absolute"
                    ],
                    "severity": "error",
                    "pattern": [
                        {
                            "regexp": "^[A-Za-z]*Exception:\\s+([A-Z]:[^:]+):(\\d+):(\\d+)$",
                            "file": 1,
                            "line": 2,
                            "column": 4
                        },
                        {
                            "regexp": "^Line\\s\\|\\s*$"
                        },
                        {
                            "regexp": "^\\s*\\d*\\s*\\|.*"
                        },
                        {
                            "regexp": "^\\s*\\|\\s*~~+\\s*$"
                        },
                        {
                            "regexp": "^\\s*\\|\\s*([^~].*)\\s*$",
                            "message": 1
                        }
                    ]
                }
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}